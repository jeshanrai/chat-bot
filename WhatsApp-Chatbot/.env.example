# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ===========================================
# WhatsApp Configuration
# ===========================================
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=your_shared_verify_token_here

# ===========================================
# Messenger Configuration
# ===========================================
MESSENGER_PAGE_ACCESS_TOKEN=your_messenger_page_token_here
MESSENGER_APP_SECRET=your_facebook_app_secret_here

# ===========================================
# Facebook App Secret (for webhook signature verification)
# ===========================================
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ===========================================
# AI/LLM Configuration
# ===========================================
# Provider options: groq, openai, gemini
LLM_PROVIDER=groq

# Groq (default)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Gemini (optional)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
# Option 1: Connection string (preferred for production)
# DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Individual settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=restaurant_bot