# Environment Variables Schema
# Copy this file to .env and fill in the values

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=3000
BASE_URL=https://your-domain.ngrok.io

# ===========================================
# WHATSAPP CLOUD API
# ===========================================
# Get these from Meta Developer Portal
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
VERIFY_TOKEN=your_webhook_verify_token

# ===========================================
# FACEBOOK MESSENGER API (Optional)
# ===========================================
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token
MESSENGER_APP_SECRET=your_app_secret

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot
# Or individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=chatbot
# DB_USER=postgres
# DB_PASSWORD=password

# ===========================================
# LLM PROVIDER
# ===========================================
# Currently supported: groq, openai, gemini
LLM_PROVIDER=groq

# Groq API (default, free tier available)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API (optional, for future use)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Google Gemini API (optional, for future use)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=debug
# Options: error, warn, info, debug

# ===========================================
# OPTIONAL FEATURES
# ===========================================
# Enable/disable features
ENABLE_RESERVATIONS=false
ENABLE_ANALYTICS=false
